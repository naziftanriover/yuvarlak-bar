rules_version = '2';
// Yuvarlak Bar — Firestore güvenlik kuralları.
// Güven tasarımının Firebase tarafındaki koruması: roller, "silme yok" (append-only),
// denetim kayıtlarını yalnızca patronun görebilmesi.
// NOT: Kâr/stok gibi hesap doğrulukları istemci + bu kurallarla korunur; küçük bir
// bar için gerçekçi tehdide (arayüzden gizleme) karşı yeterlidir.

service cloud.firestore {
  match /databases/{database}/documents {

    function girisli() {
      return request.auth != null;
    }
    function kullaniciKaydi() {
      return get(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)).data;
    }
    function aktifMi() {
      return girisli() && kullaniciKaydi().aktif == true;
    }
    function rolu() {
      return kullaniciKaydi().rol;
    }
    function rolVar(liste) {
      return aktifMi() && (rolu() in liste);
    }

    // Kullanıcılar: patron yönetir; herkes kendi kaydını okuyabilir. Silme yok.
    match /kullanicilar/{uid} {
      allow read: if girisli() && (request.auth.uid == uid || rolVar(['PATRON']));
      allow create, update: if rolVar(['PATRON']);
      allow delete: if false;
    }

    // Ürünler: giriş yapan herkes okur; yönetim patron/müdür. Silme yok (pasifleştirme).
    match /urunler/{id} {
      allow read: if girisli();
      allow create, update: if rolVar(['PATRON', 'MUDUR']);
      allow delete: if false;
    }

    // Masalar: okuma herkes; açma/taşıma/ad değişimi patron/müdür/garson. Silme yok.
    match /masalar/{id} {
      allow read: if girisli();
      allow create, update: if rolVar(['PATRON', 'MUDUR', 'GARSON']);
      allow delete: if false;
    }

    // Adisyonlar ve alt koleksiyonları.
    match /adisyonlar/{id} {
      allow read: if girisli();
      allow create, update: if rolVar(['PATRON', 'MUDUR', 'GARSON']);
      allow delete: if false;

      // Sipariş hareketleri: SADECE EKLEME. Değiştirme/silme YOK (append-only).
      match /hareketler/{hid} {
        allow read: if girisli();
        allow create: if rolVar(['PATRON', 'MUDUR', 'GARSON']);
        allow update, delete: if false;
      }
      // Ödemeler: sadece ekleme; ödeme almak patron/müdür yetkisi.
      match /odemeler/{oid} {
        allow read: if girisli();
        allow create: if rolVar(['PATRON', 'MUDUR']);
        allow update, delete: if false;
      }
    }

    // Denetim kaydı: yalnızca PATRON okur; ekleme patron/müdür; değiştirme/silme yok.
    match /denetim/{id} {
      allow read: if rolVar(['PATRON']);
      allow create: if rolVar(['PATRON', 'MUDUR']);
      allow update, delete: if false;
    }

    // Gece kapanışları: yalnızca PATRON okur; kilitli (değiştirilemez).
    match /geceKapanislari/{id} {
      allow read: if rolVar(['PATRON']);
      allow create: if rolVar(['PATRON', 'MUDUR']);
      allow update, delete: if false;
    }
  }
}
